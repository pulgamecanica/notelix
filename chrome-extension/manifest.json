{
  "name": "notelix",
  "version": "0.2.0",
  "description": "",
  "manifest_version": 3,
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Options",
    "default_popup": "extension-options.html"
  },
  "background": {
    "service_worker": "dist/background.dist.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*",
        "file:///*/*.txt"
      ],
      "js": [
        "dist/content-script.dist.js"
      ],
      "run_at": "document_end"
    }
  ]
}
